{
  "name": "sigma-gmaps-scraper",
  "version": "1.0.0",
  "description": "Desktop Google Maps business data scraper built with Electron + Playwright",
  "main": "main.js",
  "author": "Luciano Botelho",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "electron": "^38.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.sigma.scraper",
    "productName": "Sigma",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "scraper.js",
      "preload.js",
      "config.js",
      "utils/**/*",
      "assets/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/.bin",
      "!node_modules/playwright-core/node_modules",
      "!node_modules/playwright/node_modules"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "Sigma-Prospeccao.exe"
    },
    "asar": true,
    "compression": "maximum"
  }
}
